<Project>
  <PropertyGroup>
    <!-- Keep MSBuild intermediates off the exFAT game drive (1 MB clusters waste space on small files). -->
    <BaseIntermediateOutputPath>$(LOCALAPPDATA)\KRAB-9000\obj\$(MSBuildProjectName)\</BaseIntermediateOutputPath>
    <BaseOutputPath>$(LOCALAPPDATA)\KRAB-9000\bin\$(MSBuildProjectName)\</BaseOutputPath>
  </PropertyGroup>
</Project>
