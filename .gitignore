# Build artifacts (Directory.Build.props already redirects obj/bin outside
# this folder, onto C:, for exFAT reasons — these entries are just a safety
# net in case that ever changes, or for anyone building without that props file).
src/obj/
src/bin/
src/.vs/

# Internal development material — design decisions, test protocols, the
# Claude Code project hub — not part of the shipped mod, kept local only.
notes/
CLAUDE.md

# Inert dev-test scaffolding (a disabled ModuleManager patch, .txt so KSP
# never loads it) — useful while developing, not meant for the public release.
Test/GraphSample.cfg.txt

# Texture working files: only the exported .dds ships with the mod.
Parts/*.psd
Parts/*.dds.backup

# OS/editor cruft
.DS_Store
Thumbs.db
